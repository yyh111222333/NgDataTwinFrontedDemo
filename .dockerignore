# .dockerignore

# Git相关文件
.git
.gitignore
.gitattributes

# 编辑器和代码格式化工具配置
.vscode
.editorconfig
.prettierrc.json
.oxlintrc.json

# 本地敏感环境变量 (非常重要！)
.env.local

# 示例环境变量 (通常不需要在镜像中)
.env.example

# 本地或已经打包好的依赖 (镜像内通过 npm ci 或 npm install 生成)
node_modules

# 本地构建产物 (在 Dockerfile 的 builder 阶段会被生成)
dist

# Docker Compose 文件 (不直接用于构建镜像本身)
docker-compose.yml

# README 文件
README.md

# TypeScript 声明文件 (通常不需要在最终生产镜像中)
env.d.ts
