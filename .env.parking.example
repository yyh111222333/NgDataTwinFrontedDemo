# Copy these values into the deployment host's private .env file.
PARKING_PORT=19080
CAMERA_USERNAME=admin
CAMERA_PASSWORD=change-me
PARKING_ADMIN_USERNAME=admin
PARKING_ADMIN_PASSWORD=change-me
PARKING_AUTH_SECRET=replace-with-a-long-random-value
PARKING_CAPACITY=500

# K30 personnel appointments. The portal adapter works immediately through
# the existing gateway. Fill all three OpenAPI secrets to switch automatically
# to the signed AES interface described in the vendor document.
K30_PORTAL_BASE_URL=http://192.168.10.11:18050/s/personnel
K30_OPENAPI_BASE_URL=http://10.13.0.6:8050
K30_COMPANY_NO=1780491840740664
K30_DEFAULT_DEPARTMENT_NO=1782540952786460
K30_APP_SECRET=
K30_AES_KEY=
K30_AES_IV=
