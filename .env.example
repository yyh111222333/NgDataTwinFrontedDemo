# 前端容器映射端口（宿主机端口）
FRONTEND_PORT=8083

# npm 镜像源（可选）
NPM_REGISTRY=<NPM_REGISTRY_URL>

# 构建时注入前端的 API baseURL。留空即可（推荐）：
# - 本地 dev：npm run dev，Vite 将 /api、/health 代理到 localhost:8084
# - Docker：nginx 将 /api、/health 反代到后端
VITE_API_BASE_URL=

# 可选：本地 dev 代理目标（默认 http://localhost:8084）
# VITE_DEV_API_PROXY_TARGET=http://localhost:8084

